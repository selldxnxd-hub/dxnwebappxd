{
  "entities": {
    "SystemSettings": {
      "title": "SystemSettings",
      "description": "Storewide settings and PIN authentication code",
      "type": "object",
      "properties": {
        "shopName": { "type": "string" },
        "currency": { "type": "string" },
        "contactEmail": { "type": "string" },
        "contactPhone": { "type": "string" },
        "address": { "type": "string" },
        "adminPin": { "type": "string" }
      },
      "required": ["shopName", "currency", "contactEmail", "contactPhone", "address", "adminPin"]
    },
    "ThemeConfig": {
      "title": "ThemeConfig",
      "description": "Visual identity configurations of the storefront",
      "type": "object",
      "properties": {
        "primaryColor": { "type": "string" },
        "secondaryColor": { "type": "string" },
        "accentColor": { "type": "string" },
        "fontFamily": { "type": "string" },
        "logoUrl": { "type": "string" },
        "logoText": { "type": "string" },
        "heroTitle": { "type": "string" },
        "heroSubtitle": { "type": "string" },
        "heroBannerUrl": { "type": "string" },
        "darkMode": { "type": "boolean" }
      },
      "required": ["primaryColor", "secondaryColor", "accentColor", "fontFamily", "logoText", "heroTitle", "heroSubtitle", "heroBannerUrl", "darkMode"]
    },
    "Category": {
      "title": "Category",
      "description": "A product category for the storefront",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "slug": { "type": "string" },
        "description": { "type": "string" },
        "imageUrl": { "type": "string" }
      },
      "required": ["id", "name", "slug", "description"]
    },
    "Subcategory": {
      "title": "Subcategory",
      "description": "A subcategory within a parent category",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "slug": { "type": "string" },
        "categoryId": { "type": "string" }
      },
      "required": ["id", "name", "slug", "categoryId"]
    },
    "Brand": {
      "title": "Brand",
      "description": "A product brand manufacturer",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "slug": { "type": "string" },
        "logoUrl": { "type": "string" },
        "description": { "type": "string" }
      },
      "required": ["id", "name", "slug"]
    },
    "Product": {
      "title": "Product",
      "description": "A retail product listing",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "title": { "type": "string" },
        "slug": { "type": "string" },
        "description": { "type": "string" },
        "price": { "type": "number" },
        "compareAtPrice": { "type": "number" },
        "images": { "type": "array" },
        "categoryId": { "type": "string" },
        "subcategoryId": { "type": "string" },
        "brandId": { "type": "string" },
        "inventory": { "type": "number" },
        "sku": { "type": "string" },
        "isFeatured": { "type": "boolean" },
        "rating": { "type": "number" },
        "reviewsCount": { "type": "number" },
        "createdAt": { "type": "string" }
      },
      "required": ["id", "title", "slug", "description", "price", "images", "categoryId", "inventory", "sku", "isFeatured", "rating", "reviewsCount", "createdAt"]
    },
    "Order": {
      "title": "Order",
      "description": "A customer transaction order",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "customerName": { "type": "string" },
        "customerEmail": { "type": "string" },
        "customerPhone": { "type": "string" },
        "address": { "type": "string" },
        "city": { "type": "string" },
        "postalCode": { "type": "string" },
        "country": { "type": "string" },
        "items": { "type": "array" },
        "subtotal": { "type": "number" },
        "discount": { "type": "number" },
        "shipping": { "type": "number" },
        "total": { "type": "number" },
        "status": { "type": "string" },
        "paymentStatus": { "type": "string" },
        "paymentMethod": { "type": "string" },
        "couponCode": { "type": "string" },
        "createdAt": { "type": "string" }
      },
      "required": ["id", "customerName", "customerEmail", "customerPhone", "address", "city", "postalCode", "country", "items", "subtotal", "discount", "shipping", "total", "status", "paymentStatus", "paymentMethod", "createdAt"]
    },
    "Coupon": {
      "title": "Coupon",
      "description": "A discount voucher code",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "code": { "type": "string" },
        "discountType": { "type": "string" },
        "discountValue": { "type": "number" },
        "minOrderValue": { "type": "number" },
        "active": { "type": "boolean" },
        "expiryDate": { "type": "string" }
      },
      "required": ["id", "code", "discountType", "discountValue", "active", "expiryDate"]
    },
    "Review": {
      "title": "Review",
      "description": "A product customer review rating",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "productId": { "type": "string" },
        "userName": { "type": "string" },
        "userEmail": { "type": "string" },
        "rating": { "type": "number" },
        "comment": { "type": "string" },
        "active": { "type": "boolean" },
        "createdAt": { "type": "string" }
      },
      "required": ["id", "productId", "userName", "userEmail", "rating", "comment", "active", "createdAt"]
    },
    "StaticPage": {
      "title": "StaticPage",
      "description": "An informational static content page",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "title": { "type": "string" },
        "slug": { "type": "string" },
        "content": { "type": "string" },
        "active": { "type": "boolean" },
        "createdAt": { "type": "string" }
      },
      "required": ["id", "title", "slug", "content", "active", "createdAt"]
    },
    "CustomMenu": {
      "title": "CustomMenu",
      "description": "A dynamic store navigation menu structure",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "title": { "type": "string" },
        "type": { "type": "string" },
        "items": { "type": "array" }
      },
      "required": ["id", "title", "type", "items"]
    },
    "SystemNotification": {
      "title": "SystemNotification",
      "description": "Internal store alerts for new sales, ratings, or stock changes",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "title": { "type": "string" },
        "message": { "type": "string" },
        "type": { "type": "string" },
        "read": { "type": "boolean" },
        "createdAt": { "type": "string" }
      },
      "required": ["id", "title", "message", "type", "read", "createdAt"]
    }
  },
  "firestore": {
    "/settings/{id}": { "schema": "SystemSettings", "description": "Global store configurations" },
    "/theme/{id}": { "schema": "ThemeConfig", "description": "Visual colors and banner links" },
    "/categories/{id}": { "schema": "Category", "description": "Product categories" },
    "/subcategories/{id}": { "schema": "Subcategory", "description": "Product subcategories" },
    "/brands/{id}": { "schema": "Brand", "description": "Product brand labels" },
    "/products/{id}": { "schema": "Product", "description": "Physical items on sale" },
    "/orders/{id}": { "schema": "Order", "description": "Checkout transactions" },
    "/coupons/{id}": { "schema": "Coupon", "description": "Store-wide promo discount vouchers" },
    "/reviews/{id}": { "schema": "Review", "description": "Item product reviews" },
    "/pages/{id}": { "schema": "StaticPage", "description": "Custom standalone company pages" },
    "/menus/{id}": { "schema": "CustomMenu", "description": "Store navbar link collections" },
    "/notifications/{id}": { "schema": "SystemNotification", "description": "Admin operational notifications" }
  }
}
